# Data mode: "demo" (seeded, no backend needed) or "supabase"
VITE_DATA_MODE=demo
# Required only when VITE_DATA_MODE=supabase — publishable values only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# NEVER put service-role keys, Square secrets, or webhook secrets in this file
# or anywhere in the repository. Those live in Supabase function secrets.
