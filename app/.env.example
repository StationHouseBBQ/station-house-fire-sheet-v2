# Station House Fire Sheet V2 — environment template.
# Copy to .env.local and fill in values there. .env.local is gitignored.
#
#   *** NEVER commit real values to this file or any file in the repo. ***
#   *** NEVER add service-role keys (or any secret) anywhere in the     ***
#   *** frontend — every value here ships to the browser. Secrets live  ***
#   *** in Supabase function secrets / CI secrets only.                 ***

# Data mode: "demo" (seeded, no backend needed) or "supabase"
VITE_DATA_MODE=demo

# Required only when VITE_DATA_MODE=supabase — publishable values only
# (project URL + anon key; the anon key is safe to expose, RLS gates all data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: Vite only exposes variables prefixed with VITE_ to the app. The
# unprefixed spellings below do NOT work in the browser build — they are
# listed only so nobody "fixes" the config by renaming. Use the VITE_ names.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
